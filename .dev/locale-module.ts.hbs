import type { Types } from 'effect'
{{#each locales}}
  import * as l{{@key}} from './{{this}}.ts'
{{/each}}

const translations = {
{{#each locales}}
  '{{this}}': l{{@key}},
{{/each}}
}

type SupportedLocale = keyof typeof translations

export type Translations = {[K in keyof typeof translations['{{defaultLocale}}']]: Types.UnionToIntersection<[]
{{#each realLocales}}
  & (K extends keyof typeof translations['{{this}}'] ? Parameters<typeof translations['{{this}}'][K]> : [])
{{/each}}
> extends [] ? () => string : (x: Types.Simplify<{}
{{#each realLocales}}
  & (K extends keyof typeof translations['{{this}}'] ? Parameters<typeof translations['{{this}}'][K]> extends [] ? {} : Parameters<typeof translations['{{this}}'][K]>[0] : {})
{{/each}}
>) => string
}



export const translate{{moduleName}} =
  (locale: SupportedLocale) =>
  <K extends keyof Translations>(key: K): Translations[K] => {
    if (key in translations[locale]) {
      // @ts-ignore
      return translations[locale][key]
    }
    return translations['{{defaultLocale}}'][key]
  }
