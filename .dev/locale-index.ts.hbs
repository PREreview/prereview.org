import { HashSet, type Option, Record } from 'effect'
{{#each moduleNames}}
import * as {{@key}} from './{{this}}/index.ts'
{{/each}}

export type SupportedLocale = {{#each locales}}| '{{this}}'{{/each}}

export type UserSelectableLocale = Exclude<SupportedLocale, '{{crowdinInContextLocale}}'>

export type UserSelectableLanguage = {{#each languages}}| '{{@key}}'{{/each}}

export const DefaultLocale: UserSelectableLocale = '{{defaultLocale}}'

export const CrowdinInContextLocale: SupportedLocale = '{{crowdinInContextLocale}}'

export const SupportedLocales = HashSet.fromIterable<SupportedLocale>([{{#each locales}}'{{this}}', {{/each}}])

export const UserSelectableLocales = HashSet.fromIterable<SupportedLocale>([{{#each locales}}'{{this}}', {{/each}}]).pipe(HashSet.remove<SupportedLocale>('{{crowdinInContextLocale}}')) as HashSet.HashSet<UserSelectableLocale>

export const UserSelectableLanguages = HashSet.fromIterable<UserSelectableLanguage>([{{#each languages}}'{{@key}}', {{/each}}])

export const isSupportedLocale = (locale: string): locale is SupportedLocale =>
  [{{#each locales}}'{{this}}', {{/each}}].includes(locale)

export const isUserSelectableLocale = (locale: string): locale is UserSelectableLocale =>
  isSupportedLocale(locale) && locale !== '{{crowdinInContextLocale}}'

export const getLocaleForLanguage = (language: UserSelectableLanguage): SupportedLocale => ({
{{#each languages}}
  '{{@key}}': '{{this}}',
{{/each}}
} as const)[language]

export const getLanguageForLocale = (locale: UserSelectableLocale): Option.Option<UserSelectableLanguage> => Record.get({
{{#each languages}}
  '{{this}}': '{{@key}}',
{{/each}}
}, locale as never)

type Module = keyof Translations
type Key<M extends Module> = keyof Translations[M]

const modules = {
{{#each moduleNames}}
  '{{this}}': {{@key}}.translate{{@key}},
{{/each}}
}

type Translations = {
{{#each moduleNames}}
  '{{this}}': {{@key}}.Translations,
{{/each}}
}

export const translate: {
  (locale: SupportedLocale): <M extends Module, K extends Key<M>>(module: M, key: K) => Translations[M][K] 
  <M extends Module>(locale: SupportedLocale, module: M): {
    <K extends Key<M>>(key: K): Translations[M][K]
    <M2 extends Module, K extends Key<M2>>(module: M2, key: K): Translations[M2][K]
  }
  <M extends Module, K extends Key<M>>(locale: SupportedLocale, module: M, key: K): Translations[M][K] 
} =
  (locale: SupportedLocale, module?: string, key?: string) => {
    if(!module) {
      // @ts-ignore
      return (module: string | number, key: any) => modules[module](locale)(key)
    }

    if(!key) {
      return (moduleOrKey: string, key?: string) => {
        if(key) {
          // @ts-ignore
          return modules[moduleOrKey](locale)(key)
        }

        // @ts-ignore
        return modules[module](locale)(moduleOrKey)
      }
    }

    // @ts-ignore
    return modules[module](locale)(key)
  }
 